# P2P Palestine - Configuration File
# Copy this file to .env and update the values for your environment

# Database Configuration
# For Docker: use 'db' as hostname when running inside container
# For local development: use 'localhost'
DATABASE_URL=sqlite+aiosqlite:///./p2p_local.db

# Security Settings
# Generate a strong secret key for production (min 32 characters)
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=3NpX_r2O3aVkwySI_1U-Z1xuSAE5pxNADzoz7Sdllfw
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Encryption (Fernet key for sensitive data like bank details & wallet addresses)
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=pi1CiggGmnDeuogOsubaB_WC9iWEBDqLMQLoztmcq1M=

# Cloudinary Configuration (for Proof of Funds images)
# Get these from https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Application Settings
APP_NAME=P2P Palestine
DEBUG=True
